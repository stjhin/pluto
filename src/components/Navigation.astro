---
import { Rocket, Package, TrendingUp, Search, Settings } from "@lucide/astro";
// Navigation.astro — shared left sidebar for all pages
// Props: activePage — "drones" | "deliveries" | "analytics" | "search"
const { activePage = "drones" } = Astro.props;

const links = [
  { href: "/pluto/",             icon: "Rocket",      label: "Drones",     page: "drones" },
  { href: "/pluto/deliveries",   icon: "Package",     label: "Deliveries", page: "deliveries" },
  { href: "/pluto/analytics",    icon: "TrendingUp",  label: "Analytics",  page: "analytics" },
  { href: "/pluto/search",       icon: "Search",      label: "Search",     page: "search" },
  { href: "#",                   icon: "Settings",    label: "Settings",   page: "settings" },
];
---
<aside id="left-sidebar" class="mobile-sidebar hidden lg:flex w-64 bg-[#0e1220] border-r border-[#192239] flex-col justify-between shrink-0 fixed lg:relative inset-y-0 left-0 z-40 shadow-2xl lg:shadow-none">
  <div>
    <div class="p-6 border-b border-[#192239]">
      <div class="flex items-center gap-2.5 justify-between">
        <div class="flex items-center gap-2.5">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-tr from-blue-600 to-indigo-500 flex items-center justify-center text-white font-bold shadow-md shadow-blue-500/20">P</div>
          <div>
            <h1 class="text-sm uppercase font-extrabold tracking-widest text-blue-400">Pluto</h1>
            <p class="text-[11px] font-medium text-slate-500 uppercase tracking-wider">Fleet Command</p>
          </div>
        </div>
        <button id="mobile-menu-close" class="lg:hidden p-1 text-slate-400 hover:text-white -mr-1" aria-label="Close menu">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
    </div>
    <nav class="p-4 space-y-1">
      {links.map((link) => {
        const isActive = link.page === activePage;
        const linkClass = isActive
          ? "flex items-center gap-3 px-4 py-3 text-sm font-semibold text-slate-300 bg-[#171f34] border-l-2 border-blue-500 rounded-r-md transition-all"
          : "flex items-center gap-3 px-4 py-3 text-sm font-medium text-slate-400 hover:text-slate-200 hover:bg-[#12192a]/50 rounded-md transition-all group";
        const iconClass = isActive ? "w-[18px] h-[18px] text-blue-400" : "w-[18px] h-[18px] text-slate-500 group-hover:text-slate-400";
        return (
          <a href={link.href} class={linkClass}>
            {link.icon === "Rocket" && <Rocket class={iconClass} />}
            {link.icon === "Package" && <Package class={iconClass} />}
            {link.icon === "TrendingUp" && <TrendingUp class={iconClass} />}
            {link.icon === "Search" && <Search class={iconClass} />}
            {link.icon === "Settings" && <Settings class={iconClass} />}
            {link.label}
          </a>
        );
      })}
    </nav>
  </div>
  <div class="p-4 border-t border-[#192239] bg-[#0c0f1b]">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-lg bg-[#11182c] border border-blue-500/20 text-blue-400 flex items-center justify-center font-bold shadow-inner">JB</div>
      <div class="overflow-hidden">
        <p class="text-sm font-semibold text-slate-200 truncate">Justin Beckenbaur</p>
        <p class="text-[11px] text-slate-500 uppercase tracking-tight">System Admin</p>
      </div>
    </div>
  </div>
</aside>