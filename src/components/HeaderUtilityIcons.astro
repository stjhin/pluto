---
import { Bell, HelpCircle, User } from "@lucide/astro";
---
<div class="flex items-center gap-4 text-slate-400">
  <button class="relative p-1.5 hover:text-slate-200 transition-colors" aria-label="Notifications">
    <span class="absolute top-1 right-1 w-2 h-2 bg-[#ef4444] rounded-full"></span>
    <Bell class="w-4 h-4" />
  </button>
  <button class="p-1.5 hover:text-slate-200 transition-colors" aria-label="Help">
    <HelpCircle class="w-4 h-4" />
  </button>
  <button class="p-1.5 hover:text-slate-200 transition-colors border border-[#192239] rounded-full bg-[#0e1220]" aria-label="Account">
    <User class="w-4 h-4 text-slate-300" />
  </button>
</div>
