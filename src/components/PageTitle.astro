---
// PageTitle.astro — consistent page title block with optional icon via slot
// Props: description — subtitle text (optional)
const { description = "" } = Astro.props;
---
<div>
  <h2 class="text-2xl font-extrabold tracking-tight text-white mb-1.5 flex items-center gap-2">
    <slot />
  </h2>
  {description && (
    <p class="text-sm font-medium text-slate-400">{description}</p>
  )}
</div>
