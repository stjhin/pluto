---
import '../styles/global.css';

interface Props {
	title?: string;
}

const { title = "Pluto Fleet Command" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<!-- Google Fonts for Inter and JetBrains Mono or similar -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#0c101d] text-[#e2e8f0] font-sans antialiased overflow-x-hidden selection:bg-blue-500/30 selection:text-white min-h-screen">
		<slot />
	</body>
</html>

<style is:global>
	:root {
		font-family: 'Plus Jakarta Sans', system-ui, -apple-system, sans-serif;
	}
	code, pre, .font-mono {
		font-family: 'JetBrains Mono', monospace;
	}
	
	/* Custom scrollbar */
	::-webkit-scrollbar {
		width: 6px;
		height: 6px;
	}
	::-webkit-scrollbar-track {
		background: #0f1524;
	}
	::-webkit-scrollbar-thumb {
		background: #1e293b;
		border-radius: 4px;
	}
	::-webkit-scrollbar-thumb:hover {
		background: #334155;
	}
</style>
