---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import SearchBar from "../components/SearchBar.astro";
import PageTitle from "../components/PageTitle.astro";
import HeaderUtilityIcons from "../components/HeaderUtilityIcons.astro";
import {
  TrendingUp,
  Search,
  HelpCircle,
  ChevronDown,
  Download,
} from "@lucide/astro";

// Let's create mock high-quality logistics trends and ranking entries for our Analytics interface!
const rankings = [
  {
    id: "XB-72 VALKYRIE",
    missions: 142,
    efficiency: "98.4%",
    status: "ACTIVE",
    type: "active",
  },
  {
    id: "RD-09 GHOST",
    missions: 128,
    efficiency: "97.1%",
    status: "ACTIVE",
    type: "active",
  },
  {
    id: "NH-11 NIGHTHAWK",
    missions: 115,
    efficiency: "95.8%",
    status: "REFUEL",
    type: "refuel",
  },
  {
    id: "ST-04 STRIDER",
    missions: 102,
    efficiency: "94.2%",
    status: "ACTIVE",
    type: "active",
  },
];
---

<Layout title="PLUTO Fleet Command | Analytics">
  <div class="flex h-screen overflow-hidden bg-[#0a0d16] relative">
    <Navigation activePage="analytics" />

    <!-- MAIN BODY SECTION & RIGHT LOGS -->
    <div class="flex flex-1 overflow-hidden">
      <!-- CENTRAL CONTENT AREA -->
      <main class="flex-1 overflow-y-auto p-4 lg:p-8 space-y-4 lg:space-y-8 bg-[#0a0d16]">
        <!-- Header Controls -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-3 md:gap-4">
          <!-- Mobile Hamburger -->
          <button id="mobile-menu-toggle" class="lg:hidden p-1.5 text-slate-400 hover:text-white rounded-md hover:bg-[#171f34] transition-colors shrink-0 mb-1" aria-label="Open menu"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg></button>
          <div class="w-full lg:w-80">
            <SearchBar placeholder="Search analytics, telemetry..." />
          </div>

          <HeaderUtilityIcons />
        </div>

        <!-- Section Intro & Filter Toggles -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-4">
          <PageTitle description="Real-time performance telemetry and strategic mission intelligence across the drone fleet.">
            <TrendingUp class="w-6 h-6 text-blue-400" /> Analytics
          </PageTitle>

          <!-- Quick Filters Group tab -->
          <div
            class="flex bg-[#0e1220] p-1 rounded-lg border border-[#1b253b] text-slate-400 font-bold text-[11px] uppercase tracking-wider whitespace-nowrap overflow-x-auto"
            id="time-filter-tabs"
          >
            <button
              data-filter="today"
              class="px-4 py-2 hover:bg-[#161d31] hover:text-slate-200 rounded-md transition-all cursor-pointer"
              >Today</button
            >
            <button
              data-filter="week"
              class="px-4 py-2 bg-blue-600 text-white rounded-md transition-all cursor-pointer shadow-md shadow-blue-500/10"
              >Last 7 Days</button
            >
            <button
              data-filter="month"
              class="px-4 py-2 hover:bg-[#161d31] hover:text-slate-200 rounded-md transition-all cursor-pointer"
              >Last Month</button
            >
          </div>
        </div>

        <!-- Upper Metrics Block: Deliveries Trends & Battery Efficiency -->
        <div class="grid grid-cols-1 lg:grid-cols-27 gap-6">
          <!-- Box Left: Delivery Trends SVG Chart -->
          <div
            class="lg:col-span-17 bg-[#0e1220] border border-[#192239] rounded-xl p-6 relative flex flex-col justify-between"
          >
            <div class="flex justify-between items-center mb-6">
              <div>
                <p
                  class="text-[10px] font-bold text-slate-500 uppercase tracking-widest"
                >
                  Logistics Intelligence
                </p>
                <h4
                  class="text-sm font-bold text-white uppercase mt-0.5 tracking-wider"
                >
                  Delivery Trends
                </h4>
              </div>
              <div
                class="flex items-center gap-4 text-[10px] font-bold uppercase tracking-wider"
              >
                <span class="flex items-center gap-1.5 text-slate-300">
                  <span class="w-2 h-2 rounded-full bg-blue-400 inline-block"
                  ></span> Standard
                </span>
                <span class="flex items-center gap-1.5 text-slate-300">
                  <span class="w-2 h-2 rounded-full bg-emerald-400 inline-block"
                  ></span> Priority
                </span>
              </div>
            </div>

            <!-- Delivery Chart Canvas Simulation (Using pure SVG lines for gorgeous real look) -->
            <div
              class="relative h-56 w-full flex flex-col justify-between pt-4"
            >
              <!-- SVG Curves representing beautiful drone trends -->
              <svg
                class="absolute inset-0 w-full h-full"
                viewBox="0 0 500 200"
                preserveAspectRatio="none"
                id="trends-chart-svg"
              >
                <!-- Grid background horizontal guidelines -->
                <line
                  x1="0"
                  y1="50"
                  x2="500"
                  y2="50"
                  stroke="#1d263b"
                  stroke-dasharray="4,4"
                  stroke-width="0.75"></line>
                <line
                  x1="0"
                  y1="100"
                  x2="500"
                  y2="100"
                  stroke="#1d263b"
                  stroke-dasharray="4,4"
                  stroke-width="0.75"></line>
                <line
                  x1="0"
                  y1="150"
                  x2="500"
                  y2="150"
                  stroke="#1d263b"
                  stroke-dasharray="4,4"
                  stroke-width="0.75"></line>

                <!-- Glow Filters for chart lines -->
                <defs>
                  <linearGradient
                    id="blue-area-grad"
                    x1="0"
                    y1="0"
                    x2="0"
                    y2="1"
                  >
                    <stop offset="0%" stop-color="#3b82f6" stop-opacity="0.25">
                    </stop>
                    <stop offset="100%" stop-color="#3b82f6" stop-opacity="0">
                    </stop>
                  </linearGradient>
                  <linearGradient
                    id="emerald-area-grad"
                    x1="0"
                    y1="0"
                    x2="0"
                    y2="1"
                  >
                    <stop offset="0%" stop-color="#10b981" stop-opacity="0.2">
                    </stop>
                    <stop offset="100%" stop-color="#10b981" stop-opacity="0">
                    </stop>
                  </linearGradient>
                </defs>

                <!-- Blue area fill -->
                <path
                  id="blue-chart-area"
                  d="M 0 160 Q 80 155, 140 100 T 280 130 T 420 50 L 500 120 L 500 200 L 0 200 Z"
                  fill="url(#blue-area-grad)"
                ></path>

                <!-- Emerald area fill -->
                <path
                  id="emerald-chart-area"
                  d="M 0 180 Q 70 170, 150 140 T 290 120 T 420 70 L 500 100 L 500 200 L 0 200 Z"
                  fill="url(#emerald-area-grad)"
                ></path>

                <!-- Main blue trend line -->
                <path
                  id="blue-chart-line"
                  d="M 0 160 Q 80 155, 140 100 T 280 130 T 420 50 L 500 120"
                  fill="none"
                  stroke="#3b82f6"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  filter="url(#blue-glow)"
                >
                </path>

                <!-- Emerald trend line -->
                <path
                  id="emerald-chart-line"
                  d="M 0 180 Q 70 170, 150 140 T 290 120 T 420 70 L 500 100"
                  fill="none"
                  stroke="#10b981"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  filter="url(#emerald-glow)"
                >
                </path>
              </svg>

              <!-- Empty space holder for SVG placement alignment -->
              <div class="h-44"></div>

              <!-- Days Grid labels matching user mockup exactly -->
              <div
                class="flex justify-between text-[10px] font-bold text-slate-500 font-mono tracking-wider uppercase border-t border-[#192239] pt-3 relative z-10"
                id="chart-timeline-labels"
              >
                <span>Mon</span><span>Tue</span><span>Wed</span
                ><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span>
              </div>
            </div>
          </div>

          <!-- Box Right: Battery Efficiency KPI -->
          <div
            class="lg:col-span-10 bg-[#0e1220] border border-[#192239] rounded-xl p-6 relative flex flex-col justify-between"
          >
            <div>
              <p
                class="text-[10px] font-bold text-slate-500 uppercase tracking-widest"
              >
                Energy Systems
              </p>
              <h4
                class="text-sm font-bold text-white uppercase mt-0.5 tracking-wider"
              >
                Battery Efficiency %
              </h4>
            </div>

            <!-- Radial Speedometer Progress circle inside center frame context -->
            <div
              class="flex flex-col items-center justify-center my-6 relative"
            >
              <div class="relative w-36 h-36 flex items-center justify-center">
                <!-- SVG Circle representation -->
                <svg
                  class="absolute inset-0 w-full h-full transform -rotate-90"
                  viewBox="0 0 120 120"
                  id="battery-speedometer"
                >
                  <circle
                    cx="60"
                    cy="60"
                    r="52"
                    fill="none"
                    stroke="#1d263b"
                    stroke-width="8"
                  ></circle>
                  <!-- Arc dynamic with dash offset calculator -->
                  <circle
                    cx="60"
                    cy="60"
                    r="52"
                    fill="none"
                    stroke="#10b981"
                    stroke-width="8"
                    stroke-linecap="round"
                    stroke-dasharray="326.73"
                    stroke-dashoffset="40"
                  ></circle>
                </svg>
                <div
                  class="text-center font-mono font-extrabold text-white text-2xl tracking-tight"
                >
                  87<span
                    class="text-lg text-emerald-400 font-extrabold -ml-0.5"
                    >%</span
                  >
                </div>
              </div>
            </div>

            <!-- Battery health legends categorizations -->
            <div
              class="space-y-2 border-t border-[#192239] pt-4 text-[11px] font-bold uppercase tracking-wider"
            >
              <div class="flex justify-between items-center">
                <span class="flex items-center gap-2 text-slate-400">
                  <span
                    class="w-1.5 h-1.5 rounded-full bg-emerald-500 inline-block"
                  ></span> Optimal
                </span>
                <span class="font-mono text-slate-200">72%</span>
              </div>
              <div class="flex justify-between items-center">
                <span class="flex items-center gap-2 text-slate-400">
                  <span
                    class="w-1.5 h-1.5 rounded-full bg-blue-500 inline-block"
                  ></span> Recharging
                </span>
                <span class="font-mono text-slate-200">20%</span>
              </div>
              <div class="flex justify-between items-center">
                <span class="flex items-center gap-2 text-slate-400">
                  <span
                    class="w-1.5 h-1.5 rounded-full bg-rose-500 inline-block"
                  ></span> Degraded
                </span>
                <span class="font-mono text-slate-200">8%</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Lower Metrics Block: Operational Success & Fleet Rankings grid split -->
        <div class="grid grid-cols-1 lg:grid-cols-27 gap-6">
          <!-- Box Left: Drone Performance metrics / progress ranges -->
          <div
            class="lg:col-span-12 bg-[#0e1220] border border-[#192239] rounded-xl p-6 flex flex-col justify-between"
          >
            <div class="flex justify-between items-start mb-6">
              <div>
                <p
                  class="text-[10px] font-bold text-slate-500 uppercase tracking-widest"
                >
                  Operational Success
                </p>
                <h4
                  class="text-sm font-bold text-white uppercase mt-0.5 tracking-wider"
                >
                  Drone Performance
                </h4>
              </div>
              <button
                class="p-1 hover:bg-[#1a233b] rounded text-slate-500 hover:text-white transition-colors"
              >
                <ChevronDown class="w-4 h-4" />
              </button>
            </div>

            <!-- Segmented Performance sliders -->
            <div class="space-y-5">
              <!-- Grid Line A -->
              <div class="space-y-1.5">
                <div class="flex justify-between text-xs font-bold">
                  <span class="text-slate-400 tracking-wide"
                    >Mission Success</span
                  >
                  <span class="text-emerald-400 font-mono">94.2%</span>
                </div>
                <div
                  class="w-full h-1.5 bg-[#12192e] rounded-full overflow-hidden"
                >
                  <div
                    class="h-full bg-emerald-500 rounded-full"
                    style="width: 94.2%"
                  >
                  </div>
                </div>
              </div>

              <!-- Grid Line B -->
              <div class="space-y-1.5">
                <div class="flex justify-between text-xs font-bold">
                  <span class="text-slate-400 tracking-wide"
                    >Auto-Recovery Rate</span
                  >
                  <span class="text-blue-400 font-mono">82.5%</span>
                </div>
                <div
                  class="w-full h-1.5 bg-[#12192e] rounded-full overflow-hidden"
                >
                  <div
                    class="h-full bg-blue-500 rounded-full"
                    style="width: 82.5%"
                  >
                  </div>
                </div>
              </div>

              <!-- Grid Line C -->
              <div class="space-y-1.5">
                <div class="flex justify-between text-xs font-bold">
                  <span class="text-slate-400 tracking-wide">System Faults</span
                  >
                  <span class="text-rose-400 font-mono">4.1%</span>
                </div>
                <div
                  class="w-full h-1.5 bg-[#12192e] rounded-full overflow-hidden"
                >
                  <div
                    class="h-full bg-rose-400 rounded-full"
                    style="width: 4.1%"
                  >
                  </div>
                </div>
              </div>
            </div>

            <!-- Performance stats footer display metrics -->
            <div
              class="grid grid-cols-2 gap-4 border-t border-[#192239] pt-6 mt-6"
            >
              <div>
                <h3
                  class="text-2xl font-extrabold text-white font-mono leading-none"
                >
                  1,204
                </h3>
                <p
                  class="text-[10px] text-slate-500 font-bold uppercase mt-1.5 tracking-widest"
                >
                  Total Sorties
                </p>
              </div>
              <div class="pl-4 border-l border-[#192239]">
                <h3
                  class="text-2xl font-extrabold text-white font-mono leading-none"
                >
                  12.4s
                </h3>
                <p
                  class="text-[10px] text-slate-500 font-bold uppercase mt-1.5 tracking-widest"
                >
                  Avg Latency
                </p>
              </div>
            </div>
          </div>

          <!-- Box Right: Fleet Rankings Table Display mapping exactly to mock design screenshot -->
          <div
            class="lg:col-span-15 bg-[#0e1220] border border-[#192239] rounded-xl p-6 relative flex flex-col justify-between"
          >
            <div class="flex justify-between items-center mb-6">
              <div>
                <p
                  class="text-[10px] font-bold text-slate-500 uppercase tracking-widest"
                >
                  Fleet Rankings
                </p>
                <h4
                  class="text-sm font-bold text-white uppercase mt-0.5 tracking-wider"
                >
                  Top Performing Units
                </h4>
              </div>
              <button
                class="flex items-center gap-1.5 px-3 py-1.5 bg-[#171f34] hover:bg-[#1e2947] border border-[#233155] rounded-l text-[11px] uppercase tracking-wider font-bold text-slate-300 transition-colors shadow"
              >
                <Download class="w-3.5 h-3.5" />
                Export CSV
              </button>
            </div>

            <!-- Fleet ranking index telemetry lists -->
            <div class="overflow-x-auto">
              <table class="w-full text-left text-xs border-collapse">
                <thead>
                  <tr
                    class="text-[10px] font-bold text-slate-500 uppercase tracking-wider border-b border-[#1b253b] pb-2"
                  >
                    <th class="py-2.5">Unit ID</th>
                    <th class="py-2.5">Missions</th>
                    <th class="py-2.5">Efficiency</th>
                    <th class="py-2.5 text-right">Status</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-[#151b2e]/80">
                  {
                    rankings.map((unit) => (
                      <tr class="hover:bg-[#121827]/40 transition-colors">
                        <td class="py-3 font-bold text-slate-200 flex items-center gap-2">
                          <span class="text-blue-400">
                            <svg
                              class="w-3.5 h-3.5 rotate-45 inline-block"
                              fill="none"
                              stroke="currentColor"
                              viewBox="0 0 24 24"
                            >
                              <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2.5"
                                d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"
                              />
                            </svg>
                          </span>
                          {unit.id}
                        </td>
                        <td class="py-3 font-mono text-slate-400">
                          {unit.missions}
                        </td>
                        <td class="py-3 font-mono font-bold text-[#10b981]">
                          {unit.efficiency}
                        </td>
                        <td class="py-3 text-right">
                          {unit.status === "ACTIVE" ? (
                            <span class="text-[10px] font-bold tracking-wider text-emerald-400 uppercase bg-emerald-500/10 border border-emerald-500/20 px-2 py-0.5 rounded">
                              {unit.status}
                            </span>
                          ) : (
                            <span class="text-[10px] font-bold tracking-wider text-slate-400 uppercase bg-slate-500/10 border border-slate-500/20 px-2 py-0.5 rounded animate-pulse">
                              {unit.status}
                            </span>
                          )}
                        </td>
                      </tr>
                    ))
                  }
                </tbody>
              </table>
            </div>

            <!-- Footer expand link -->
            <div class="border-t border-[#192239] pt-4 mt-4 text-center">
              <a
                href="#"
                class="text-[10px] hover:text-blue-400 tracking-wider font-bold text-slate-500 uppercase transition-all"
              >
                View All Fleet Data
              </a>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>

  <!-- Interactive script to handle Dynamic quick-filter switching states seamlessly -->
  <script>
    (() => {
      const filterButtons = document.querySelectorAll("#time-filter-tabs button");
      if (!filterButtons.length) return;

      const blueLine = document.getElementById("blue-chart-line");
      const blueArea = document.getElementById("blue-chart-area");
      const emeraldLine = document.getElementById("emerald-chart-line");
      const emeraldArea = document.getElementById("emerald-chart-area");
      const timelineLabels = document.getElementById("chart-timeline-labels");

      const ACTIVE_CLASS = "px-4 py-2 bg-blue-600 text-white rounded-md transition-all cursor-pointer shadow-md shadow-blue-500/10";
      const INACTIVE_CLASS = "px-4 py-2 hover:bg-[#161d31] hover:text-slate-200 rounded-md transition-all cursor-pointer";

      const datasets = {
        today: {
          blueLine: "M 0 170 C 50 180, 100 130, 150 145 C 200 160, 250 80, 300 95 C 350 110, 400 150, 500 60",
          blueArea: "M 0 170 C 50 180, 100 130, 150 145 C 200 160, 250 80, 300 95 C 350 110, 400 150, 500 60 L 500 200 L 0 200 Z",
          emeraldLine: "M 0 190 C 50 160, 100 170, 150 110 C 200 120, 250 100, 300 70 C 350 130, 400 90, 500 120",
          emeraldArea: "M 0 190 C 50 160, 100 170, 150 110 C 200 120, 250 100, 300 70 C 350 130, 400 90, 500 120 L 500 200 L 0 200 Z",
          timeline: ["04:00", "08:00", "12:00", "16:00", "20:00", "22:00", "24:00"],
        },
        week: {
          blueLine: "M 0 160 Q 80 155, 140 100 T 280 130 T 420 50 L 500 120",
          blueArea: "M 0 160 Q 80 155, 140 100 T 280 130 T 420 50 L 500 120 L 500 200 L 0 200 Z",
          emeraldLine: "M 0 180 Q 70 170, 150 140 T 290 120 T 420 70 L 500 100",
          emeraldArea: "M 0 180 Q 70 170, 150 140 T 290 120 T 420 70 L 500 100 L 500 200 L 0 200 Z",
          timeline: ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"],
        },
        month: {
          blueLine: "M 0 100 Q 100 150, 200 80 T 400 120 T 500 50",
          blueArea: "M 0 100 Q 100 150, 200 80 T 400 120 T 500 50 L 500 200 L 0 200 Z",
          emeraldLine: "M 0 130 Q 110 80, 220 120 T 380 90 T 500 80",
          emeraldArea: "M 0 130 Q 110 80, 220 120 T 380 90 T 500 80 L 500 200 L 0 200 Z",
          timeline: ["Week 1", "Week 2", "Week 3", "Week 4", "Week 5", "Week 6", "Week 7"],
        },
      };

      filterButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
          filterButtons.forEach((b) => { b.className = INACTIVE_CLASS; });
          btn.className = ACTIVE_CLASS;

          const filterVal = btn.getAttribute("data-filter") || "week";
          const targetData = datasets[filterVal];
          if (!targetData) return;

          blueLine?.setAttribute("d", targetData.blueLine);
          blueArea?.setAttribute("d", targetData.blueArea);
          emeraldLine?.setAttribute("d", targetData.emeraldLine);
          emeraldArea?.setAttribute("d", targetData.emeraldArea);

          if (timelineLabels) {
            timelineLabels.innerHTML = targetData.timeline.map((lbl) => `<span>${lbl}</span>`).join("");
          }
        });
      });
    })();
  </script>
</Layout>