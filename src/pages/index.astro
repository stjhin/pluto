---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import SearchBar from "../components/SearchBar.astro";
import Drawer from "../components/Drawer.astro";
import PageTitle from "../components/PageTitle.astro";
import HeaderUtilityIcons from "../components/HeaderUtilityIcons.astro";
import {
  Rocket,
  Package,
  TrendingUp,
  Search,
  HelpCircle,
  Sparkles,
  ArrowUpRight,
  CheckCircle2,
  X,
  Battery,
  Signal,
  MapPin,
  RefreshCw,
  SlidersHorizontal,
  ChevronDown,
  Download,
  Terminal as TerminalIcon,
  CircleDot,
} from "@lucide/astro";
import fs from "node:fs";
import path from "node:path";
import { parse } from "csv-parse/sync";

// Parse Drone fleet data from .csv database file dynamically
const csvFilePath = path.join(process.cwd(), "src/data/drones.csv");
const fileContent = fs.readFileSync(csvFilePath, "utf-8");
const parsedRecords = parse(fileContent, {
  columns: true,
  skip_empty_lines: true,
  cast: true,
});

// Format CSV records to match our structure
const drones = parsedRecords.map((record: any) => ({
  id: String(record.id),
  location: String(record.location),
  status: String(record.status),
  statusColor:
    record.status === "IN-TRANSIT"
      ? "blue"
      : record.status === "MAINTENANCE"
        ? "red"
        : "gray",
  attempts: Number(record.attempts),
  success: Number(record.success),
  pct: Number(record.pct),
}));

const deliveryLogs = [
  {
    id: "DRN-X902",
    time: "14:22:18 UTC",
    address: "742 Tech Plaza, Suite 400, North Sector",
    type: "success",
  },
  {
    id: "DRN-V210",
    time: "13:45:02 UTC",
    address: "12 Market St, Main Entrance, Downtown",
    type: "success",
  },
  {
    id: "DRN-X118",
    time: "13:12:44 UTC",
    address: "East Terminal Cargo Bay C-14",
    type: "success",
  },
];

const failedLogs = [
  {
    id: "DRN-M441",
    time: "12:04:15 UTC",
    address: "404 Industrial Way, Processing Bay 3",
    type: "failed",
  },
  {
    id: "DRN-X114",
    time: "10:55:22 UTC",
    address: "89 Skyline Boulevard, Penthouse C",
    type: "failed",
  },
];
---

<Layout title="PLUTO Fleet Command | Drones">
  <div class="flex h-screen overflow-hidden bg-[#0a0d16] relative">
    <Navigation activePage="drones" />

    <!-- MAIN BODY SECTION & RIGHT LOGS -->
    <div class="flex flex-1 overflow-hidden">
      <!-- CENTRAL CONTENT AREA -->
      <main
        class="flex-1 overflow-y-auto p-4 lg:p-8 space-y-4 lg:space-y-8 bg-[#0a0d16] lg:border-r border-[#192239]"
      >
        <!-- Header Controls -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-3 md:gap-4">
          <!-- Mobile hamburger + Live Status -->
          <div class="flex items-center gap-3 w-full md:w-auto">
            <!-- Hamburger menu button (mobile only) -->
            <button id="mobile-menu-toggle" class="lg:hidden p-1.5 text-slate-400 hover:text-white rounded-md hover:bg-[#171f34] transition-colors shrink-0" aria-label="Open menu">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
              </svg>
            </button>
            <div class="flex items-center gap-2">
            <span class="relative flex h-2 w-2">
              <span
                class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"
              ></span>
              <span
                class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"
              ></span>
            </span>
            <span
              class="text-xs font-semibold tracking-wider text-slate-400 uppercase"
              >Live Operations Active</span
            >
          </div>
          </div>

          <div class="w-full lg:w-80">
            <SearchBar placeholder="Search drone ID, coordinates, status..." />
          </div>

          <HeaderUtilityIcons />
        </div>

        <PageTitle description="Tactical overview of active drones and mission efficiency metrics">
          <Rocket class="w-6 h-6 text-blue-400" /> Drones
        </PageTitle>

        <!-- Metric Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 lg:gap-6">
          <!-- Card 1: Total Delivery -->
          <div
            class="relative overflow-hidden bg-gradient-to-b from-[#111727] to-[#0e1321] border border-[#1d263f] rounded-xl p-6 transition-all duration-300 hover:border-[#283556]"
          >
            <!-- Subtle backdrop gradient -->
            <div
              class="absolute -top-12 -right-12 w-32 h-32 bg-blue-500/5 rounded-full blur-3xl"
            >
            </div>

            <div class="flex justify-between items-start mb-4 relative z-10">
              <div>
                <p
                  class="text-xs font-bold text-slate-400 tracking-wider uppercase mb-1"
                >
                  Total Delivery
                </p>
                <h3 class="text-3xl font-extrabold text-white tracking-tight">
                  1,248
                </h3>
              </div>
              <button
                id="open-drawer-btn"
                class="p-2.5 bg-blue-500/10 rounded-lg border border-blue-500/20 text-blue-400 hover:bg-blue-500/20 hover:border-blue-500/30 transition-all cursor-pointer shadow-md shadow-blue-500/5 focus:outline-none relative z-20 pointer-events-auto"
                title="Open Delivery Logs"
              >
                <Package class="w-5 h-5 pointer-events-none" />
              </button>
            </div>

            <div
              class="flex items-center justify-between pt-2 border-t border-[#1a233b] gap-4"
            >
              <div class="flex-1 min-w-0">
                <!-- Bar Visualization -->
                <div class="flex justify-between text-xs mb-1.5">
                  <span class="text-slate-400 font-medium"
                    >Mission Goal Progress</span
                  >
                  <span class="text-blue-400 font-semibold">82%</span>
                </div>
                <div
                  class="w-full h-1.5 bg-[#172033] rounded-full overflow-hidden"
                >
                  <div
                    class="h-full bg-gradient-to-r from-blue-500 to-indigo-500 rounded-full"
                    style="width: 82%"
                  >
                  </div>
                </div>
              </div>
              <div
                class="flex items-center gap-1.5 shrink-0 text-[#10b981] font-bold text-xs"
              >
                <span>+12%</span>
                <span class="text-[11px] text-slate-500 font-medium font-sans"
                  >MoM</span
                >
              </div>
            </div>
          </div>

          <!-- Card 2: Total Successful Delivery -->
          <div
            class="relative overflow-hidden bg-gradient-to-b from-[#111727] to-[#0e1321] border border-[#1d263f] rounded-xl p-6 transition-all duration-300 hover:border-[#283556]"
          >
            <!-- Subtle backdrop gradient -->
            <div
              class="absolute -top-12 -right-12 w-32 h-32 bg-emerald-500/5 rounded-full blur-3xl"
            >
            </div>

            <div class="flex justify-between items-start mb-4">
              <div>
                <p
                  class="text-xs font-bold text-slate-400 tracking-wider uppercase mb-1"
                >
                  Total Successful Delivery
                </p>
                <div class="flex items-baseline gap-2">
                  <h3
                    class="text-3xl font-extrabold text-[#10b981] tracking-tight"
                  >
                    94.2%
                  </h3>
                </div>
              </div>
              <div
                class="p-2.5 bg-emerald-500/10 rounded-lg border border-emerald-500/20 text-[#10b981]"
              >
                <CheckCircle2 class="w-5 h-5" />
              </div>
            </div>

            <div
              class="flex items-center justify-between pt-2 border-t border-[#1a233b] gap-4"
            >
              <div class="flex-1 min-w-0">
                <!-- Bar Visualization -->
                <div class="flex justify-between text-xs mb-1.5">
                  <span class="text-slate-400 font-medium">Status</span>
                  <span class="text-[#10b981] font-semibold"
                    >Stable Fleet Operations</span
                  >
                </div>
                <div
                  class="w-full h-1.5 bg-[#172033] rounded-full overflow-hidden"
                >
                  <div
                    class="h-full bg-[#10b981] rounded-full"
                    style="width: 94.2%"
                  >
                  </div>
                </div>
              </div>
              <div
                class="flex items-center gap-1 shrink-0 text-[#10b981] font-bold text-xs border border-emerald-500/15 py-1 px-2 rounded-md bg-[#10b981]/5"
              >
                <span
                  class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse"
                ></span>
                <span
                  class="text-[11px] text-[#10b981] font-bold uppercase tracking-wider"
                  >Stable</span
                >
              </div>
            </div>
          </div>
        </div>

        <!-- Table Panel: Drone Fleet Status -->
        <div
          class="bg-[#0e1220] border border-[#192239] rounded-xl overflow-hidden shadow-lg"
        >
          <!-- Panel Header -->
          <div
            class="p-5 border-b border-[#192239] flex justify-between items-center bg-[#111628]"
          >
            <div>
              <h3 class="text-sm font-bold text-white tracking-wide uppercase">
                Drone Fleet Status
              </h3>
              <p class="text-xs text-slate-400 font-medium">
                Detailed tracking and state indicators of individual models
              </p>
            </div>
            <div class="flex items-center gap-2">
              <button
                class="flex items-center gap-2 px-3 py-1.5 bg-[#171f34] hover:bg-[#1e2947] border border-[#233155] rounded-lg text-xs font-bold text-slate-300 transition-colors"
              >
                <SlidersHorizontal class="w-3.5 h-3.5 text-slate-400" />
                All Status
                <ChevronDown class="w-3.5 h-3.5 text-slate-500" />
              </button>
            </div>
          </div>

          <!-- Interactive Table -->
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse" id="drone-table">
              <thead>
                <tr class="border-b border-[#172036] bg-[#0c101d]/60">
                  <th
                    class="py-3 px-5 text-[11px] font-bold tracking-wider text-slate-400 uppercase"
                    >Drone ID</th
                  >
                  <th
                    class="py-3 px-5 text-[11px] font-bold tracking-wider text-slate-400 uppercase"
                    >Location</th
                  >
                  <th
                    class="py-3 px-5 text-[11px] font-bold tracking-wider text-slate-400 uppercase"
                    >Status</th
                  >
                  <th
                    class="py-3 px-5 text-[11px] font-bold tracking-wider text-slate-400 uppercase text-center"
                    >Attempts</th
                  >
                  <th
                    class="py-3 px-5 text-[11px] font-bold tracking-wider text-slate-400 uppercase text-center"
                    >Success Rate</th
                  >
                </tr>
              </thead>
              <tbody class="divide-y divide-[#151b2e]">
                {
                  drones.map((drone, idx) => (
                    <tr
                      class={`hover:bg-[#121827]/70 transition-colors group drone-row cursor-pointer ${idx >= 7 ? "hidden" : ""}`}
                      data-index={idx}
                      data-id={drone.id}
                      data-location={drone.location}
                      data-status={drone.status}
                      data-attempts={drone.attempts}
                      data-success={drone.success}
                      data-pct={drone.pct}
                    >
                      <td class="py-3.5 px-5 font-mono text-xs font-bold text-slate-200 group-hover:text-blue-400 transition-colors">
                        {drone.id}
                      </td>
                      <td class="py-3.5 px-5 text-xs font-medium text-slate-300 flex items-center gap-2">
                        <MapPin class="w-3.5 h-3.5 text-slate-500 shrink-0" />
                        {drone.location}
                      </td>
                      <td class="py-3.5 px-5">
                        {drone.status === "IN-TRANSIT" && (
                          <div class="inline-flex items-center gap-1.5 py-0.5 px-2 bg-blue-500/10 border border-blue-500/20 rounded-md text-[11px] font-bold text-blue-400 uppercase tracking-wider">
                            <CircleDot class="w-3 h-3 animate-pulse" />
                            In-Transit
                          </div>
                        )}
                        {drone.status === "IDLE" && (
                          <div class="inline-flex items-center gap-1.5 py-0.5 px-2 bg-slate-500/10 border border-slate-500/25 rounded-md text-[11px] font-bold text-slate-400 uppercase tracking-wider">
                            <CircleDot class="w-3 h-3" />
                            Idle
                          </div>
                        )}
                        {drone.status === "MAINTENANCE" && (
                          <div class="inline-flex items-center gap-1.5 py-0.5 px-2 bg-rose-500/10 border border-rose-500/20 rounded-md text-[11px] font-bold text-rose-400 uppercase tracking-wider">
                            <CircleDot class="w-3 h-3" />
                            Maintenance
                          </div>
                        )}
                      </td>
                      <td class="py-3.5 px-5 font-mono text-xs font-bold text-slate-300 text-center">
                        {drone.attempts}
                      </td>
                      <td class="py-3.5 px-5 text-center">
                        <div class="flex items-center justify-center gap-2">
                          <span
                            class={`font-mono text-xs font-bold ${drone.pct >= 95 ? "text-[#10b981]" : drone.pct >= 90 ? "text-blue-400" : "text-amber-400"}`}
                          >
                            {drone.pct}%
                          </span>
                          <span class="text-[11px] text-slate-500 font-sans font-medium">
                            ({drone.success}/{drone.attempts})
                          </span>
                        </div>
                      </td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </div>

          <!-- Table Summary Footer -->
          <div
            class="p-4 bg-[#111628] border-t border-[#192239] flex justify-between items-center text-xs text-slate-400 font-semibold"
          >
            <span id="pagination-indicator"
              >Showing <strong class="text-white" id="range-start">1</strong
              >-<strong class="text-white" id="range-end">7</strong> of <strong
                class="text-white"
                id="total-count">{drones.length}</strong
              > active units</span
            >
            <div class="flex gap-2">
              <button
                id="prev-page-btn"
                class="px-3 py-1 bg-[#161d31] hover:bg-[#1a233b] hover:text-white rounded border border-[#212c49] text-slate-400 cursor-pointer transition-colors disabled:opacity-30 disabled:cursor-not-allowed"
                >Prev</button
              >
              <button
                id="next-page-btn"
                class="px-3 py-1 bg-[#161d31] hover:bg-[#1a233b] hover:text-white rounded border border-[#212c49] text-slate-400 cursor-pointer transition-colors disabled:opacity-30 disabled:cursor-not-allowed"
                >Next</button
              >
            </div>
          </div>
        </div>

        <!-- Lower Analytics Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 lg:gap-6">
          <!-- Left: Operational Performance -->
          <div
            class="bg-[#0e1220] border border-[#192239] rounded-xl p-6 shadow-md space-y-6"
          >
            <h4
              class="text-sm font-bold text-white uppercase tracking-wide flex items-center gap-2"
            >
              <TrendingUp class="w-4 h-4 text-emerald-400" />
              Operational Performance
            </h4>

            <div class="space-y-4">
              <!-- Item 1 -->
              <div class="space-y-1.5">
                <div class="flex justify-between text-xs">
                  <span class="text-slate-400 font-medium"
                    >Battery Health Aggregate</span
                  >
                  <span class="text-emerald-400 font-bold">91%</span>
                </div>
                <div
                  class="w-full h-2 bg-[#172033] rounded-full overflow-hidden"
                >
                  <div
                    class="h-full bg-emerald-500 rounded-full"
                    style="width: 91%"
                  >
                  </div>
                </div>
              </div>

              <!-- Item 2 -->
              <div class="space-y-1.5">
                <div class="flex justify-between text-xs">
                  <span class="text-slate-400 font-medium"
                    >Signal Integrity Area Coverage</span
                  >
                  <span class="text-blue-400 font-bold">84%</span>
                </div>
                <div
                  class="w-full h-2 bg-[#172033] rounded-full overflow-hidden"
                >
                  <div
                    class="h-full bg-blue-500 rounded-full"
                    style="width: 84%"
                  >
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Right: Regional Traffic Control -->
          <div
            class="relative overflow-hidden bg-[#0e1220] border border-[#192239] rounded-xl p-6 shadow-md flex flex-col justify-between"
          >
            <div class="space-y-2 z-10">
              <h4 class="text-sm font-bold text-white uppercase tracking-wide">
                Regional Traffic Control
              </h4>
              <p class="text-xs text-slate-400 font-medium leading-relaxed">
                Real-time airspace calculations, routing collisions prevention,
                and vector visualizations for active drone sectors.
              </p>
            </div>

            <div class="pt-6 z-10">
              <button
                class="w-full py-2.5 px-4 bg-[#1b253e] hover:bg-[#233154] border border-[#2b3b64] text-slate-300 font-bold text-xs rounded-lg flex items-center justify-center gap-2 transition-colors"
              >
                <TerminalIcon class="w-4 h-4 text-blue-400" />
                Open Global Tactical Map
              </button>
            </div>

            <!-- Blueprint background deco -->
            <div
              class="absolute inset-0 opacity-10 pointer-events-none bg-[radial-gradient(ellipse_at_bottom_right,_var(--tw-gradient-stops))] from-blue-500 via-transparent to-transparent"
            >
            </div>
          </div>
        </div>
      </main>

      <Drawer id="delivery-logs-drawer" title="Delivery Logs" visible={true}>
        <!-- Category Tabs -->
        <div class="flex border-b border-[#172036] -mt-2">
          <button
            id="success-tab-btn"
            class="flex-1 pb-3 text-center border-b-2 border-blue-500 text-xs font-bold text-white transition-all cursor-pointer"
          >
            Successful
          </button>
          <button
            id="failed-tab-btn"
            class="flex-1 pb-3 text-center border-b-2 border-transparent text-xs font-medium text-slate-500 hover:text-slate-400 transition-all cursor-pointer"
          >
            Failed
          </button>
        </div>

        <!-- SUCCESS LOGS -->
        <div id="success-logs-container" class="space-y-4">
          {
            deliveryLogs.map((log) => (
              <div class="p-4 bg-[#121828] border border-[#1f2a46]/50 rounded-lg space-y-3 hover:border-blue-500/20 transition-all duration-300">
                <div class="flex justify-between items-center">
                  <div class="flex items-center gap-2">
                    <div class="p-1.5 bg-emerald-500/10 text-emerald-400 rounded-md border border-emerald-500/20">
                      <CheckCircle2 class="w-3.5 h-3.5" />
                    </div>
                    <span class="font-mono text-xs font-bold text-slate-200">
                      {log.id} Delivered
                    </span>
                  </div>
                  <span class="font-mono text-[10px] font-semibold text-slate-500 uppercase tracking-tight">
                    {log.time}
                  </span>
                </div>
                <p class="text-xs text-slate-400 font-medium leading-normal pl-7 flex items-start gap-1.5">
                  <span class="inline-block w-1.5 h-1.5 bg-slate-600 rounded-full mt-1.5 shrink-0" />
                  {log.address}
                </p>
              </div>
            ))
          }
        </div>

        <!-- FAILED LOGS (Hidden initially) -->
        <div id="failed-logs-container" class="space-y-4 hidden">
          {
            failedLogs.map((log) => (
              <div class="p-4 bg-[#121828] border border-rose-500/20 rounded-lg space-y-3 hover:border-rose-500/30 transition-all duration-300">
                <div class="flex justify-between items-center">
                  <div class="flex items-center gap-2">
                    <div class="p-1.5 bg-rose-500/10 text-rose-400 rounded-md border border-rose-500/20">
                      <X class="w-3.5 h-3.5" />
                    </div>
                    <span class="font-mono text-xs font-bold text-slate-200">
                      {log.id} Offline / Aborted
                    </span>
                  </div>
                  <span class="font-mono text-[10px] font-semibold text-rose-500/70 uppercase tracking-tight">
                    {log.time}
                  </span>
                </div>
                <p class="text-xs text-slate-400 font-medium leading-normal pl-7 flex items-start gap-1.5">
                  <span class="inline-block w-1.5 h-1.5 bg-rose-600 rounded-full mt-1.5 shrink-0" />
                  {log.address}
                </p>
              </div>
            ))
          }
        </div>

        <!-- Metric Summary Block -->
        <div class="border-t border-[#1a233b] pt-6 mt-6 space-y-4">
          <h4
            class="text-[11px] font-bold text-slate-400 tracking-wider uppercase"
          >
            Metric Summary
          </h4>

          <div class="space-y-3.5">
            <div class="flex justify-between items-center text-xs">
              <span class="text-slate-400 font-medium"
                >Avg. Delivery Time</span
              >
              <span class="text-white font-bold font-mono">14m 22s</span>
            </div>
            <div class="flex justify-between items-center text-xs">
              <span class="text-slate-400 font-medium"
                >Battery Efficiency</span
              >
              <span class="text-emerald-400 font-bold font-mono">92%</span>
            </div>
            <div class="flex justify-between items-center text-xs">
              <span class="text-slate-400 font-medium">Signal Strength</span>
              <span class="text-white font-bold font-mono">-42 dBm</span>
            </div>
          </div>
        </div>

        <!-- Export Button -->
        <div class="pt-4">
          <button
            class="w-full py-3 bg-[#3b82f6] hover:bg-blue-600 text-white font-bold text-xs rounded-lg flex items-center justify-center gap-2 shadow-lg shadow-blue-500/10 transition-colors"
          >
            <Download class="w-4 h-4" />
            Export Full Log
          </button>
        </div>
      </Drawer>
      <Drawer id="drone-detail-drawer" title="Drone Details">
        <div class="flex items-center gap-2">
          <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-[10px] font-bold uppercase bg-indigo-500/10 text-indigo-400 border border-indigo-500/20">Drone</span>
          <span id="drone-detail-status-badge" class="inline-flex items-center gap-1.5 py-0.5 px-2 rounded-md text-[11px] font-bold uppercase tracking-wider border bg-blue-500/10 border-blue-500/20 text-blue-400"></span>
        </div>

        <div class="space-y-3">
          <div class="flex justify-between items-start gap-4 py-2 border-b border-[#192239]/50">
            <span class="text-[11px] font-bold text-slate-500 uppercase tracking-wider shrink-0">Drone ID</span>
            <span id="drone-detail-id" class="text-xs font-mono font-bold text-slate-200 text-right"></span>
          </div>
          <div class="flex justify-between items-start gap-4 py-2 border-b border-[#192239]/50">
            <span class="text-[11px] font-bold text-slate-500 uppercase tracking-wider shrink-0">Location</span>
            <span id="drone-detail-location" class="text-xs text-slate-200 text-right"></span>
          </div>
          <div class="flex justify-between items-start gap-4 py-2 border-b border-[#192239]/50">
            <span class="text-[11px] font-bold text-slate-500 uppercase tracking-wider shrink-0">Status</span>
            <span id="drone-detail-status" class="text-xs font-medium text-slate-200 text-right"></span>
          </div>
          <div class="flex justify-between items-start gap-4 py-2 border-b border-[#192239]/50">
            <span class="text-[11px] font-bold text-slate-500 uppercase tracking-wider shrink-0">Total Attempts</span>
            <span id="drone-detail-attempts" class="text-xs font-mono font-bold text-slate-200 text-right"></span>
          </div>
          <div class="flex justify-between items-start gap-4 py-2 border-b border-[#192239]/50">
            <span class="text-[11px] font-bold text-slate-500 uppercase tracking-wider shrink-0">Successful</span>
            <span id="drone-detail-success" class="text-xs font-mono font-bold text-slate-200 text-right"></span>
          </div>
          <div class="flex justify-between items-start gap-4 py-2 border-b border-[#192239]/50">
            <span class="text-[11px] font-bold text-slate-500 uppercase tracking-wider shrink-0">Success Rate</span>
            <span id="drone-detail-pct" class="text-xs font-mono font-bold text-right"></span>
          </div>
        </div>

        <div class="pt-2">
          <div class="flex justify-between text-[11px] text-slate-400 font-medium mb-1.5">
            <span>Success Rate</span>
            <span id="drone-detail-pct-bar-label" class="font-bold"></span>
          </div>
          <div class="w-full h-1.5 bg-[#172033] rounded-full overflow-hidden">
            <div id="drone-detail-pct-bar" class="h-full rounded-full transition-all"></div>
          </div>
          <p id="drone-detail-ratio" class="text-[11px] text-slate-500 mt-1.5"></p>
        </div>
      </Drawer>
    </div>
  </div>
  <div id="drawer-overlay" class="fixed inset-0 bg-black/60 z-30 hidden lg:hidden transition-opacity duration-300" aria-hidden="true"></div>

  <script>
    (() => {
      // ── Delivery Logs Drawer ──
      const openBtn = document.getElementById("open-drawer-btn");
      const closeBtn = document.getElementById("delivery-logs-drawer-close");
      const drawer = document.getElementById("delivery-logs-drawer");
      const drawerOverlay = document.getElementById("drawer-overlay");

      const isMobile = () => window.innerWidth < 1024;

      const open = () => {
        if (!drawer) return;
        drawer.style.display = "flex";
        if (isMobile()) {
          drawerOverlay?.classList.remove("hidden");
          document.body.style.overflow = "hidden";
        }
      };

      const close = () => {
        if (!drawer) return;
        drawer.style.display = "none";
        if (isMobile()) {
          drawerOverlay?.classList.add("hidden");
          document.body.style.overflow = "";
        }
      };

      openBtn?.addEventListener("click", (e) => {
        e.preventDefault();
        if (!drawer) return;
        const hidden = drawer.style.display === "none" || drawer.style.display === "";
        hidden ? open() : close();
      });

      closeBtn?.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();
        close();
      });

      drawerOverlay?.addEventListener("click", close);

      // ── Pagination ──
      const rows = document.querySelectorAll(".drone-row");
      const totalItems = rows.length;
      const totalPages = Math.ceil(totalItems / 7);

      const prevBtn = document.getElementById("prev-page-btn") as HTMLButtonElement | null;
      const nextBtn = document.getElementById("next-page-btn") as HTMLButtonElement | null;
      const rangeStart = document.getElementById("range-start");
      const rangeEnd = document.getElementById("range-end");

      let currentPage = 1;

      const updatePagination = () => {
        if (!prevBtn || !nextBtn) return;
        if (!rangeStart || !rangeEnd) return;
        prevBtn.disabled = currentPage === 1;
        nextBtn.disabled = currentPage === totalPages || totalPages === 0;

        const startIdx = (currentPage - 1) * 7;
        const endIdx = Math.min(startIdx + 7, totalItems);

        rangeStart.textContent = totalItems === 0 ? "0" : String(startIdx + 1);
        rangeEnd.textContent = String(endIdx);

        rows.forEach((row) => {
          const idxAttr = row.getAttribute("data-index");
          if (idxAttr === null) return;
          const idx = parseInt(idxAttr, 10);
          row.classList.toggle("hidden", idx < startIdx || idx >= endIdx);
        });
      };

      if (prevBtn && nextBtn) {
        prevBtn.addEventListener("click", (e) => {
          e.preventDefault();
          if (currentPage > 1) { currentPage--; updatePagination(); }
        });

        nextBtn.addEventListener("click", (e) => {
          e.preventDefault();
          if (currentPage < totalPages) { currentPage++; updatePagination(); }
        });

        updatePagination();
      }

      // ── Tab Toggle ──
    const successTabBtn = document.getElementById("success-tab-btn");
    const failedTabBtn = document.getElementById("failed-tab-btn");
    const successLogs = document.getElementById("success-logs-container");
    const failedLogs = document.getElementById("failed-logs-container");

      if (!successTabBtn || !failedTabBtn || !successLogs || !failedLogs) return;

      const ACTIVE = ["border-blue-500", "text-white", "font-bold"];
      const INACTIVE = ["border-transparent", "text-slate-500", "font-medium"];

      const activateTab = (active, inactive) => {
        active.classList.add(...ACTIVE);
        active.classList.remove(...INACTIVE);
        inactive.classList.remove(...ACTIVE);
        inactive.classList.add(...INACTIVE);
      };

      successTabBtn.addEventListener("click", () => {
        activateTab(successTabBtn, failedTabBtn);
        successLogs.classList.remove("hidden");
        failedLogs.classList.add("hidden");
      });

      failedTabBtn.addEventListener("click", () => {
        activateTab(failedTabBtn, successTabBtn);
        failedLogs.classList.remove("hidden");
        successLogs.classList.add("hidden");
      });
      // ── Drone Row Click → Drone Details Drawer ──
      const droneDetailDrawer = document.getElementById("drone-detail-drawer");

      document.querySelectorAll(".drone-row").forEach(row => {
        row.addEventListener("click", () => {
          // Highlight selected row
          document.querySelectorAll(".drone-row").forEach(r => {
            r.classList.remove("bg-blue-950/30", "border-l-2", "border-blue-500");
          });
          row.classList.add("bg-blue-950/30", "border-l-2", "border-blue-500");

          const get = (attr) => row.getAttribute(attr) || "";
          const id = get("data-id");
          const location = get("data-location");
          const status = get("data-status");
          const attempts = get("data-attempts");
          const success = get("data-success");
          const pct = Number(get("data-pct"));
          const pctColor = pct >= 95 ? "#10b981" : pct >= 90 ? "#60a5fa" : "#f59e0b";

          // Populate detail fields
          const el = (sel) => document.querySelector(`#drone-detail-drawer ${sel}`);
          const set = (sel, val) => { const e = el(sel); if (e) e.textContent = val; };
          set("#drone-detail-id", id);
          set("#drone-detail-location", location);
          set("#drone-detail-status", status);
          set("#drone-detail-attempts", attempts);
          set("#drone-detail-success", success);
          set("#drone-detail-pct", `${pct}%`);
          set("#drone-detail-ratio", `${success} of ${attempts} attempts successful`);

          const pctLabel = el("#drone-detail-pct-bar-label");
          if (pctLabel) { pctLabel.textContent = `${pct}%`; pctLabel.style.color = pctColor; }

          const pctBar = el("#drone-detail-pct-bar");
          if (pctBar) { pctBar.style.width = `${pct}%`; pctBar.style.background = pctColor; }

          // Status badge
          const badge = el("#drone-detail-status-badge");
          if (badge) {
            badge.textContent = status;
            badge.className = "inline-flex items-center gap-1.5 py-0.5 px-2 rounded-md text-[11px] font-bold uppercase tracking-wider border";
            const colors = status === "IN-TRANSIT" ? ["bg-blue-500/10", "border-blue-500/20", "text-blue-400"]
              : status === "MAINTENANCE" ? ["bg-rose-500/10", "border-rose-500/20", "text-rose-400"]
              : ["bg-slate-500/10", "border-slate-500/25", "text-slate-400"];
            badge.classList.add(...colors);
          }

          // Open the drone detail drawer
          if (droneDetailDrawer) droneDetailDrawer.style.display = "flex";
        });
      });

    })();
  </script>
</Layout>